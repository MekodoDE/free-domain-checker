# Domain Configuration
# For large lists mount a ConfigMap at /domains and set DOMAINS_FILE accordingly
# The file should contain one domain per line. Lines starting with '#' are ignored.
DOMAINS_FILE=/domains

# SMTP Configuration
# SMTP server settings for sending notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_TO_EMAIL=notifications@yourdomain.com
SMTP_USE_TLS=true

# Check Configuration
# The container runs once and exits. Schedule it externally (for example with a Kubernetes CronJob).